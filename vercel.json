{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/tools",
      "destination": "https://blender-digital-tools.vercel.app/tools"
    },
    {
      "source": "/tools/:path*",
      "destination": "https://blender-digital-tools.vercel.app/tools/:path*"
    }
  ]
}
